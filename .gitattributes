# Default: auto-detect text vs binary, normalize text to LF on checkout
* text=auto eol=lf

# Be explicit about file types that must be LF on every platform
*.sh    text eol=lf
*.tin   text eol=lf
*.lua   text eol=lf
*.py    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.conf  text eol=lf

# Windows-side files: keep CRLF
*.bat   text eol=crlf
*.ps1   text eol=crlf
