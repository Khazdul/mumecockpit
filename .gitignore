
# Log files — regenerated at runtime

logs/



# Runtime data — generated at runtime; skeleton dirs tracked via .gitkeep

data/runs/*
data/comm/*
data/characters/*
data/shared/*
!data/**/.gitkeep



# Temporary command files generated by tintin_cmd()

bridge/ipc/cmd_*.tin



# tmux and system files

*.tmp

# Profile files — personal user data
ttpp/profiles/*
!ttpp/profiles/.gitkeep

bridge/dev/*.conf
data/shared/clock.state

# Runtime state — generated at runtime; skeleton dir tracked via .gitkeep
bridge/runtime/*
!bridge/runtime/.gitkeep



# Python bytecode

__pycache__/
*.pyc



# Editor backups

*.bak



# VS Code settings (optional — remove if you want to sync these)

.vscode/

# Private scripts

lua/scripts/autostab.lua
lua/scripts/autobow.lua

# WSL clipboard helper — downloaded by bootstrap, never tracked
bin/

# Claude Code harness transient lock (not project state)
.claude/scheduled_tasks.lock
