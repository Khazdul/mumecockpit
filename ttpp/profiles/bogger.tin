#alias {rock}     {get rock pack;use rock %0;op %0;#variable {dörr} {%0};get rock}
#alias {rd}       {get fragment pack;use fragment exit d;op exit d;#variable {dörr} {exit d};get fragment}
#alias {re}       {get fragment pack;use fragment exit e;op exit e;#variable {dörr} {exit e};get fragment}
#alias {rn}       {get fragment pack;use fragment exit n;op exit n;#variable {dörr} {exit n};get fragment}
#alias {rs}       {get fragment pack;use fragment exit s;op exit s;#variable {dörr} {exit s};get fragment}
#alias {ru}       {get fragment pack;use fragment exit u;op exit u;#variable {dörr} {exit u};get fragment}
#alias {rw}       {get fragment pack;use fragment exit w;op exit w;#variable {dörr} {exit w};get fragment}
#alias {rx}       {get fragment pack;use fragment exit;op exit;#variable {dörr} {exit};get fragment}
#alias {rdd}      {get fragment pack;use fragment $dörr;op $dörr;get fragment}
#alias {rff}      {g rock all;use rock fracturedfloor;sd fracturedfloor;g rock}

