#nop ===== HOTKEYS / MACROS =====

#nop ----- Verified function keys & TAB -----
#macro {\eOP} {k *man*}
#nop F1 → kill *man*  (originally JMC #hot {F1})

#macro {\eOS} {k $targ}
#nop F4 → kill current target

#macro {\e[23~} {ass $ass}
#nop F11 → assist $ass

#macro {\e[24~} {ass $friend}
#nop F12 → assist $friend

#macro {\t} {exa $targ;con $targ}
#nop TAB → examine + consider target

#nop ----- TODO: numpad bindings (require terminal verification) -----
#nop In tmux/xterm with application-keypad mode ON, numpad arrows
#nop send the same sequences as the regular arrows, which collides
#nop with line editing. With NumLock on they send literal digits.
#nop Capture the actual sequences in YOUR terminal (e.g. run `cat`
#nop and press the keys) before uncommenting.
#nop
#nop Original JMC bindings:
#nop   #hot {NUM0} {open $sd}
#nop   #hot {NUM1} {u}
#nop   #hot {NUM2} {s}
#nop   #hot {NUM3} {d}
#nop   #hot {NUM4} {w}
#nop   #hot {NUM5} {flee}
#nop   #hot {NUM6} {e}
#nop   #hot {NUM7} {call}
#nop   #hot {NUM8} {n}
#nop   #hot {NUM9} {say open}
#nop   #hot {MIN} {pick $sd}      (numpad -)
#nop   #hot {ADD} {close $sd}     (numpad +)
#nop   #hot {MUL} {lock $sd}      (numpad *)
#nop   #hot {DIV} {unlock $sd}    (numpad /)
#nop
#nop Likely candidates (xterm application-keypad mode):
#nop   #macro {\eOp} {open $sd}     NUM0
#nop   #macro {\eOq} {u}            NUM1
#nop   #macro {\eOr} {s}            NUM2
#nop   #macro {\eOs} {d}            NUM3
#nop   #macro {\eOt} {w}            NUM4
#nop   #macro {\eOu} {flee}         NUM5
#nop   #macro {\eOv} {e}            NUM6
#nop   #macro {\eOw} {call}         NUM7
#nop   #macro {\eOx} {n}            NUM8
#nop   #macro {\eOy} {say open}     NUM9
#nop   #macro {\eOm} {pick $sd}     MIN
#nop   #macro {\eOl} {close $sd}    ADD
#nop   #macro {\eOj} {lock $sd}     MUL
#nop   #macro {\eOo} {unlock $sd}   DIV

#nop ----- TODO: modifier combos (need terminal capture) -----
#nop Original JMC bindings:
#nop   #hot {Ctrl+NUM5} {cha wimpy 999}
#nop   #hot {Ctrl+NUM9} {sa close}
#nop
#nop Ctrl+numpad behaviour varies wildly between terminals.
#nop Most terminals don't distinguish Ctrl+digit from plain digit
#nop on the numpad. Consider rebinding to function-key combos or
#nop printable shortcuts instead.


