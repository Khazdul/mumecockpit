#nop {{ ---- generic fallbacks for unlisted mobs (two-tone) ---- }};
#substitute {^{[A-Z].*} is standing here{[^(]*}} {<FFFFFFF>!  <FA8A8A8>%1<F6E6E6E> is standing here%2<088>}
#substitute {^{[A-Z].*} is sleeping here{[^(]*}} {<FFFFFFF>!  <FA8A8A8>%1<F6E6E6E> is sleeping here%2<088>}
#substitute {^{[A-Z].*} is lying here{,[^(]*}} {<FFFFFFF>!  <FA8A8A8>%1<F6E6E6E> is lying here%2<088>}
#substitute {^{[A-Z].*} is {[^(]*here, fighting[^(]*}} {<FFFFFFF>!  <FA8A8A8>%1<F6E6E6E> is %2<088>}
#substitute {^{The shadow of .*} is floating here{[^(]*}} {<FFFFFFF>!  <FA8A8A8>%1<F6E6E6E> is floating here%2<088>}

#nop {{ ---- flag subs (white parens, coloured word) ---- }};
#substitute {(glowing)} {<FFFFFFF>(<FDA9BFF>glowing<FFFFFFF>)<088>}
#substitute {(hidden)}  {<FFFFFFF>(<FA8A8A8>hidden<FFFFFFF>)<088>}
