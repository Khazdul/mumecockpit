#nop { =================================================================== };
#nop {  Mume readability module - Mobs (room contents) };
#nop {  446 named subs + 5 generic fallbacks + 2 flag subs };
#nop {  };
#nop {  Two-tone: NAME in its tier colour, BODY ('is here' + the };
#nop {  trailing period) always dark grey. Prefix '!  ' is white. };
#nop {  };
#nop {  Colour legend (tt++ truecolor, see #help colors): };
#nop {    <FFFFFFF>  white   '!  ' marker + flag parens };
#nop {    <FA8A8A8> grey    trivial name / generic name / (hidden)  #a8a8a8 };
#nop {    <F6E6E6E> grey    body 'is here' + period (all tiers)     #6e6e6e };
#nop {    <FDAA520> gold    dangerous / named / boss / special      #daa520 };
#nop {    <FDB7093> pink    roots / snare                           #db7093 };
#nop {    <FDA9BFF> lilac   (glowing) word                          #da9bff };
#nop {    <088>  reset to default colour };
#nop {  };
#nop {  Red and slate-grey are retired: red is the game's own damage };
#nop {  colour, so the readability layer never uses it. };
#nop {  };
#nop {  Named subs consume the sentence period (the trailing '.' in the };
#nop {  pattern) so the body+period render dark; a following (glowing)/ };
#nop {  (hidden) is left as leftover text for the flag subs to colour. };
#nop {  Generics capture the name before the verb phrase and stop %2 };
#nop {  before any flag paren ([^(]*) for the same reason. };
#nop {  };
#nop {  Named subs are read before the generics, so a known mob always };
#nop {  wins; rewriting to 'is here' also stops the generic verb match. };
#nop {  };
#nop {  Install:  #read mume_readability_mobs.tin };
#nop {  Remove:   #killall substitute };
#nop { =================================================================== };

#nop {{ ---- named mobs (two-tone, consumed period) ---- }};
