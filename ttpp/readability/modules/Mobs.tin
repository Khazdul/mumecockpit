#nop {{ ---- generic fallbacks for unlisted mobs (two-tone) ---- }};
#substitute {^{[A-Z].*} is standing here{[^(]*}} {%1<F6E6E6E> is standing here%2<088>}
#substitute {^{[A-Z].*} is sleeping here{[^(]*}} {%1<F6E6E6E> is sleeping here%2<088>}
#substitute {^{[A-Z].*} is lying here{,[^(]*}} {%1<F6E6E6E> is lying here%2<088>}
#substitute {^{[A-Z].*} is {[^(]*here, fighting[^(]*}} {%1<F6E6E6E> is %2<088>}
#substitute {^{The shadow of .*} is floating here{[^(]*}} {%1<F6E6E6E> is floating here%2<088>}

