#nop { =================================================================== };
#nop {  Mume readability module - Mobs (room contents) };
#nop {  Credits: Lamia (original mob list). };
#nop {  446 named subs + 5 generic fallbacks + 2 flag subs };
#nop {  };
#nop {  No prefix: each line is NAME (tier colour) + BODY ('is here' };
#nop {  + trailing period) in dark grey. Lines start in column 0 like };
#nop {  room text; colour alone distinguishes a mob from description. };
#nop {  };
#nop {  Colour legend (tt++ truecolor, see #help colors): };
#nop {     (trivial / generic / unlisted names render in the default colour) };
#nop {    <F6E6E6E> grey       body 'is here' + period            #6e6e6e };
#nop {    <FF0C850> gold       dangerous / named / boss / special #f0c850 };
#nop {    <FEF6FA6> pink       roots / snare                      #ef6fa6 };
#nop {    <FFFFFFF>  white      flag parens only };
#nop {     (hidden) word uses the dark grey above; (glowing) uses lilac };
#nop {    <FDA9BFF> lilac      (glowing) word                    #da9bff };
#nop {    <088>  reset to default colour };
#nop {  };
#nop {  Trivial mobs use NO name colour: the dark-grey body alone };
#nop {  marks them, keeping the palette minimal. Gold/pink reserved for };
#nop {  dangerous and roots. Red/slate retired (red = game damage). };
#nop {  };
#nop {  Named subs consume the sentence period (trailing '.' in the };
#nop {  pattern) so body+period render dark; a following (glowing)/ };
#nop {  (hidden) is left as leftover for the flag subs. Generics stop };
#nop {  %2 before any flag paren ([^(]*) for the same reason. tt++ does };
#nop {  not re-scan substituted text, so flags must stay leftover. };
#nop {  };
#nop {  Named subs are read before the generics; rewriting to 'is here' };
#nop {  also stops the generic verb match, so a known mob always wins. };
#nop {  };
#nop {  Install:  #read mume_readability_mobs.tin };
#nop {  Remove:   #killall substitute };
#nop { =================================================================== };

#nop {{ ---- named mobs (two-tone, no prefix, consumed period) ---- }};
