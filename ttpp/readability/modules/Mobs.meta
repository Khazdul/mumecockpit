description = "Mume readability - room-contents mobs. Each verbose mob line becomes a short two-tone \"<name> is here.\" with no prefix: dangerous / named / boss names are gold, roots / snare names pink, and trivial names keep the default colour - only the dark-grey body ('is here.' + the period) marks them, keeping the palette minimal. Flags sit in white parens: (glowing) bright lilac, (hidden) dark grey. 446 named mobs + 5 generic fallbacks (also two-tone, default name) for unlisted mobs. Red is retired so it never clashes with the game's own damage colour. Examples below are a representative selection, live tt++ render. Credits: Lamia (original mob list)."

example_before = [
    "A squirrel scampers around here, looking for nuts from the trees.",
    "A grey wolf is here, salivating profusely.",
    "Bill Ferny is watching you with suspicious eyes.",
    "A huge, black bear is here, proud heir to the great and ancient mountain bears.",
    "Some roots lie here waiting to ensnare weary travellers.",
    "A pair of tiny eyes gleam at you from the shadows.",
    "An old man, swathed in a great light-coloured cloak, is standing here.",
    "A red-eyed shaman of the Morgundul tribe is here, chanting in evil tongues. (glowing)",
    "An orc-guard is on patrol here. (hidden)",
    "A wandering nameless pilgrim is standing here.",
    "An old, wise tree with penetrating green eyes stands here.",
]

