#ALIAS {sd}
{
    #if {"%1" != ""}
    {
        #variable {sd1} {%1};
        #if {"%2" != ""}
        {
            #variable {sd2} {%2}
        };
        #if {"%3" != ""}
        {
            #variable {sd3} {%3}
        }
    };
    #variable {_sd_line} {};
    #if {"$sd1" != ""}
    {
        #variable {_sd_line} {$_sd_line<F9AA8B7> SD1: <FFFFFFF>$sd1}
    };
    #if {"$sd2" != ""}
    {
        #variable {_sd_line} {$_sd_line<F9AA8B7>  SD2: <FFFFFFF>$sd2}
    };
    #if {"$sd3" != ""}
    {
        #variable {_sd_line} {$_sd_line<F9AA8B7>  SD3: <FFFFFFF>$sd3}
    };
    #if {"$_sd_line" != ""}
    {
        #showme {<F9AA8B7>##$_sd_line<099>}
    };
    #else
    {
        #showme {<F9AA8B7>## (no spam doors set)<099>}
    }
}

