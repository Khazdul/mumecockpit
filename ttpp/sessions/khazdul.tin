#ALIAS {z}
{
    #if {"%1" != ""}
    {
        #variable {target} {%1}
    };
    #if {"$target" != ""}
    {
        #showme {<F9AA8B7>## TARGET: <FFFFFFF>$target<099>}
    };
    #else
    {
        #showme {<F9AA8B7>## TARGET: <099>(none)}
    }
}

#MACRO {\eOP}
{
    _send hit $target
}

#MACRO {\eOQ}
{
    #if {"$class" == "warrior"}
    {
        _send bash $target
    };
    #elseif {"$class" == "caster" || "$class" == "warcaster"}
    {
        _send cast $ss $spell $target
    };
    #elseif {"$class" == "thief"}
    {
        _send backstab $target
    }
}

#MACRO {\eOR}
{
    #if {"$class" == "warrior"}
    {
        _send bash
    };
    #elseif {"$class" == "caster" || "$class" == "warcaster"}
    {
        _send cast $ss $spell
    };
    #elseif {"$class" == "thief"}
    {
        _send shoot $mees
    }
}

#MACRO {\eOS}
{
    #if {"$class" == "warrior" || "$class" == "warcaster"}
    {
        _send kick
    };
    #elseif {"$class" == "caster" || "$class" == "thief"}
    {
        _send shoot $mees
    }
}

#MACRO {\e[20~}
{
    _send sc
}

#SUBSTITUTE {- stored spell%1} {<F8c1ebb>%0<900>} {5}
#SUBSTITUTE {^%1 seems to be blinded!} {<F23aaee>%0<900>} {5}
#SUBSTITUTE {^%1(AA)%2} {<F2ab464>%0<900>} {5}
#SUBSTITUTE {^%1(B)%2} {<F2ab464>%0<900>} {5}
#SUBSTITUTE {^%1(BB)%2} {<F2ab464>%0<900>} {5}
#SUBSTITUTE {^%1(CC)%2} {<F2ab464>%0<900>} {5}
#SUBSTITUTE {^%1(DD)%2} {<F2ab464>%0<900>} {5}
#SUBSTITUTE {^%1(MIN)%2} {<F00ffff>%0<900>} {5}
#SUBSTITUTE {^- armour} {<F55ffff>%0<900>} {5}
#SUBSTITUTE {^- bless} {<F55ffff>%0<900>} {5}
#SUBSTITUTE {^- breath of briskness} {<F55ffff>%0<900>} {5}
#SUBSTITUTE {^- comfortable} {<F00aa00>%0<900>} {5}
#SUBSTITUTE {^- depressed} {<Fffaa00>%0<900>} {5}
#SUBSTITUTE {^- detect evil} {<F55ffff>%0<900>} {5}
#SUBSTITUTE {^- detect magic} {<F55ffff>%0<900>} {5}
#SUBSTITUTE {^- haggardness} {<Fffaa00>%0<900>} {5}
#SUBSTITUTE {^- lethargy} {<Fffaa00>%0<900>} {5}
#SUBSTITUTE {^- night vision} {<F55ffff>%0<900>} {5}
#SUBSTITUTE {^- potion} {<F00aa00>%0<900>} {5}
#SUBSTITUTE {^- protection from evil} {<F55ffff>%0<900>} {5}
#SUBSTITUTE {^- sanctuary} {<Ff700ff>%0<900>} {5}
#SUBSTITUTE {^- sense life} {<F55ffff>%0<900>} {5}
#SUBSTITUTE {^- shield} {<F55ffff>%0<900>} {5}
#SUBSTITUTE {^- shroud} {<F55ffff>%0<900>} {5}
#SUBSTITUTE {^- strength} {<F55ffff>%0<900>} {5}
#SUBSTITUTE {^- tiredness} {<Fffaa00>%0<900>} {5}
#SUBSTITUTE {^- very comfortable} {<F00aa00>%0<900>} {5}
#SUBSTITUTE {^-%1disease%2} {<Fff0000>%0<900>} {5}
#SUBSTITUTE {^-%1draught%2} {<F00aa00>%0<900>} {5}
#SUBSTITUTE {^-%1miruvor%2} {<F00aa00>%0<900>} {5}
#SUBSTITUTE {^-%1wound%2} {<Fff0000>%0<900>} {5}
#SUBSTITUTE {^A pair of tiny eyes gleam at you from the shadows.} {<F00ffff>%0<900>} {5}
#TICKER {clock} {#lua {state.world.clock.tick()}} {0.25}
#VARIABLE {_sd_line} {<F9AA8B7> SD1: <FFFFFFF>exit}
#VARIABLE {abody} {}
#VARIABLE {acontainer} {quiver}
#VARIABLE {arrow} {arrow}
#VARIABLE {character} {}
#VARIABLE {class} {caster}
#VARIABLE {mees} {}
#VARIABLE {ring} {golden-ruby-ring}
#VARIABLE {sd1} {exit}
#VARIABLE {sd2} {}
#VARIABLE {sd3} {}
#VARIABLE {spell} {'blindness'}
#VARIABLE {ss} {normal}
#VARIABLE {target} {chieftain}

