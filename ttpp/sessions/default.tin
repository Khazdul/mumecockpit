#ACTION {WARNING}
{
    sc
}

#ALIAS {2}
{
    _send close $sd2
}

#ALIAS {3}
{
    _send open $sd2
}

#ALIAS {_eq_body}
{
    #if {"%1" != "$abody"}
    {
        #if {"$abody" != ""}
        {
            _send rem $abody
        };
        _send get %1 pack;
        _send wear %1;
        #if {"$abody" != ""}
        {
            _send put $abody pack
        };
        #variable {abody} {%1}
    }
}

#ALIAS {_eq_ring}
{
    #if {"%1" != "$ring"}
    {
        #if {"$ring" != ""}
        {
            _send rem $ring
        };
        _send get %1 sable;
        _send wear %1;
        #if {"$ring" != ""}
        {
            _send put $ring sable
        };
        #variable {ring} {%1}
    }
}

#ALIAS {_show_acontainer}
{
    #showme {<F9AA8B7>## ARROW CONTAINER: <FFFFFFF>$acontainer  <F9AA8B7>(ammo: <FFFFFFF>$arrow<F9AA8B7>)<099>}
}

#ALIAS {_show_class}
{
    #showme {<F9AA8B7>## CLASS: <FFFFFFF>$class<099>}
}

#ALIAS {_show_spell}
{
    #if {"$spell" != ""}
    {
        #showme {<F9AA8B7>## SPELL: <FFFFFFF>$spell<099>}
    };
    #else
    {
        #showme {<F9AA8B7>## SPELL: <099>(none)}
    }
}

#ALIAS {_show_spell_speed}
{
    #showme {<F9AA8B7>## SPELL-SPEED: <FFFFFFF>$ss<099>}
}

#ALIAS {aa}
{
    _send order followers assist
}

#ALIAS {ab}
{
    _send order bb bash
}

#ALIAS {acontainer}
{
    #if {"%1" == "quiver" || "%1" == "case"}
    {
        #variable {acontainer} {%1};
        #if {"$acontainer" == "quiver"}
        {
            #variable {arrow} {arrow}
        };
        #else
        {
            #variable {arrow} {bolt}
        };
        _show_acontainer
    };
    #else
    {
        #if {"%1" != ""}
        {
            #showme {<F9AA8B7>## ERROR: acontainer must be 'quiver' or 'case'<099>}
        };
        #else
        {
            _show_acontainer
        }
    }
}

#ALIAS {azure}
{
    _send get azurescroll all;
    #if {"%1" != ""}
    {
        _send recite azurescroll %0
    };
    #else
    {
        _send recite azurescroll
    }
}

#ALIAS {bb}
{
    _send bash $target
}

#ALIAS {bd}
{
    _send cast n 'block door' $sd1
}

#ALIAS {bdd}
{
    _send cast q 'block door' $sd1
}

#ALIAS {be}
{
    _send cast n 'block door' $sd1 e
}

#ALIAS {bear}
{
    z *bear*
}

#ALIAS {bed}
{
    _send cast n 'block door' $sd1 d
}

#ALIAS {bh}
{
    #variable {spell} {'burning hands'};
    _show_spell
}

#ALIAS {bhc}
{
    _eq_body hooded
}

#ALIAS {black}
{
    _send get blackscroll all;
    #if {"%1" != ""}
    {
        _send recite blackscroll %0
    };
    #else
    {
        _send recite blackscroll
    }
}

#ALIAS {blind}
{
    #variable {spell} {'blindness'};
    _show_spell
}

#ALIAS {blue}
{
    _send get bluescroll all;
    #if {"%1" != ""}
    {
        _send recite bluescroll %0
    };
    #else
    {
        _send recite bluescroll
    }
}

#ALIAS {bolt}
{
    #variable {spell} {'lightning bolt'};
    _show_spell
}

#ALIAS {boots}
{
    _send rem boots;
    _send wear 2.boots
}

#ALIAS {bs}
{
    _send cast n 'block door' $sd1 s
}

#ALIAS {bt}
{
    _send order bb bash $target
}

#ALIAS {bu}
{
    _send cast n 'block door' $sd1 u
}

#ALIAS {burn}
{
    #variable {spell} {'burning hands'};
    _show_spell
}

#ALIAS {bw}
{
    _send cast n 'block door' $sd1 w
}

#ALIAS {c}
{
    _send close $sd1
}

#ALIAS {car}
{
    #variable {ss} {careful};
    _show_spell_speed
}

#ALIAS {case}
{
    acontainer case
}

#ALIAS {caster}
{
    #variable {class} {caster};
    _show_class
