#CONFIG {DEBUG TELNET} {OFF}
#EVENT {SESSION DEACTIVATED}
{
    #class {default} {write} {ttpp/sessions/default.tin};
    #system {bash $HOME/MUME/bridge/sanitize_profile.sh ttpp/sessions/default.tin}
}

#MACRO {\eOP}
{
    _send hit $target
}

#MACRO {\eOQ}
{
    #if {"$class" == "warrior"}
    {
        _send bash $target
    };
    #elseif {"$class" == "caster" || "$class" == "warcaster"}
    {
        _send cast $ss $spell $target
    };
    #elseif {"$class" == "thief"}
    {
        _send backstab $target
    }
}

#MACRO {\eOR}
{
    #if {"$class" == "warrior"}
    {
        _send bash
    };
    #elseif {"$class" == "caster" || "$class" == "warcaster"}
    {
        _send cast $ss $spell
    };
    #elseif {"$class" == "thief"}
    {
        _send shoot $mees
    }
}

#MACRO {\eOS}
{
    #if {"$class" == "warrior" || "$class" == "warcaster"}
    {
        _send kick
    };
    #elseif {"$class" == "caster" || "$class" == "thief"}
    {
        _send shoot $mees
    }
}

#MACRO {\e[20~}
{
    _send sc
}

#SUBSTITUTE {- stored spell%1} {<F8c1ebb>%0<900>} {5}
#SUBSTITUTE {^%1 seems to be blinded!} {<F23aaee>%0<900>} {5}
