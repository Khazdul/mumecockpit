#macro {\e[15~} {_send draw $weap1}
#macro {\e[17~} {_send draw $weap2}
#macro {\e[18~} {_send draw $weap3}
#macro {\e[20~} {_send sc}
#macro {\eOP} {_send hit $target}
#macro {\eOQ} {#if {"$class" == "warrior"}
{
_send bash $target
};
#elseif {"$class" == "caster" || "$class" == "warcaster"}
{
_send cast $ss $spell $target
};
#elseif {"$class" == "thief"}
{
_send backstab $target
}}
#macro {\eOR} {#if {"$class" == "warrior"}
{
_send bash
};
#elseif {"$class" == "caster" || "$class" == "warcaster"}
{
_send cast $ss $spell
};
#elseif {"$class" == "thief"}
{
_send shoot
}}
#macro {\eOS} {#if {"$class" == "warrior" || "$class" == "warcaster"}
{
_send kick
};
#elseif {"$class" == "caster" || "$class" == "thief"}
{
_send shoot $target
}}

#SUBSTITUTE {^%1 seems to be blinded!} {<F23aaee>%0<900>} {5}
#SUBSTITUTE {^-%1wound%2} {<Fff0000>%0<900>} {5}

#TICKER {clock} {#lua {state.world.clock.tick()}} {0.25}

