#action {^%1 raises her hand.$} {group %1}
#action {^%1 raises his hand.$} {group %1}
#action {^%1key: '%2'$} {#showme %0}
#action {^You are already wearing an ebony tunic on your body.$} {#variable {body} {tunic}}
#action {^You wear a coarse dusky robe on your body.$} {#variable {body} {robe}}
#action {^You wear a fine metal breastplate on your body.$} {#variable {body} {plate}}
#action {^You wear a frayed tunic on your body.$} {#variable {body} {tunic}}
#action {^You wear a grey tunic on your body.$} {#variable {body} {tunic}}
#action {^You wear a shining breastplate on your body.$} {#variable {body} {plate}}
#action {^You wear a shining chain mail shirt on your body.$} {#variable {body} {shirt}}
#action {^You wear an ebony tunic on your body.$} {#variable {body} {tunic}}
#action {WARNING} {sc}

#alias {2} {_send close $sd2}
#alias {3} {_send open $sd2}
#alias {^b%+1..d$} {_send cast $ss 'blindness' %1.$target}
#alias {_eq_body} {#if {"%1" != "$abody"}
{
#if {"$abody" != ""}
{
    _send rem $abody
};
_send get %1 pack;
_send wear %1;
#if {"$abody" != ""}
{
    _send put $abody pack
};
#variable {abody} {%1}
}}
#alias {_eq_ring} {#if {"%1" != "$ring"}
{
#if {"$ring" != ""}
{
    _send rem $ring
};
_send get %1 sable;
_send wear %1;
#if {"$ring" != ""}
{
    _send put $ring sable
};
#variable {ring} {%1}
}}
#alias {_show_acontainer} {#showme {<F9AA8B7>## ARROW CONTAINER: <FFFFFFF>$acontainer  <F9AA8B7>(ammo: <FFFFFFF>$arrow<F9AA8B7>)<099>}}
#alias {_show_class} {#showme {<F9AA8B7>## CLASS: <FFFFFFF>$class<099>}}
#alias {_show_spell} {#if {"$spell" != ""}
{
#showme {<F9AA8B7>## SPELL: <FFFFFFF>$spell<099>}
};
#else
{
#showme {<F9AA8B7>## SPELL: <099>(none)}
}}
#alias {_show_spell_speed} {#showme {<F9AA8B7>## SPELL-SPEED: <FFFFFFF>$ss<099>}}
#alias {a1} {push forostar north;
push orrostar east;
push hyarrostar southeast;
push hyarnustar southwest;
push andustar west;
push mittalmar center}
#alias {a2} {push forostar east;
push orrostar southeast;
push hyarrostar southwest;
push hyarnustar west;
push andustar north;
push mittalmar center}
#alias {a3} {push forostar southeast;
push orrostar southwest;
push hyarrostar west;
push hyarnustar north;
push andustar east;
push mittalmar center}
#alias {a4} {push forostar southwest;
push orrostar west;
push hyarrostar north;
push hyarnustar east;
push andustar southeast;
